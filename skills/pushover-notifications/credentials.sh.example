# Pushover credentials for sending push notifications.
#
# Copy this file to ~/.config/pushover/credentials.sh and fill in your values:
#
#   mkdir -p ~/.config/pushover
#   cp credentials.sh.example ~/.config/pushover/credentials.sh
#   chmod 600 ~/.config/pushover/credentials.sh
#
# KEEP PRIVATE — never commit real tokens to a shared repository.
# "API token" in Pushover = the application token. "Client token" = the user/group key.
export PUSHOVER_APP_TOKEN="your-application-token-here"
export PUSHOVER_USER_KEY="your-user-or-group-key-here"
